        </mxCell>
        <mxCell id="amwudx_AnwF5la0syEjV-13" value="步骤4：配准精炼用更清晰的HR重新对齐所有帧" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
